# ============================================================
# TRIPS TO TRAVELS – Copy to .env.local and fill in values
# ============================================================
# Production: set ALL required vars. Travel APIs are optional;
# when set, /api/travel/flights and /api/travel/hotels use real data.
# ============================================================

# --- REQUIRED (production) ---
MONGODB_URI=mongodb://localhost:27017/trips-to-travels
JWT_SECRET=your-secret-change-in-production
JWT_EXPIRES_IN=7d

# --- Email (Gmail: use App Password for Triptotravelsofficial@gmail.com) ---
SMTP_MAIL_FROM=Triptotravelsofficial@gmail.com
SMTP_APP_PASSWORD=

# --- Razorpay (required for real payments) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Travel provider (mock | amadeus | skyscanner | kayak | booking). Frontend never knows which. ---
TRAVEL_PROVIDER=mock

# --- Travel APIs (optional – add when you have keys; backend uses them automatically) ---
# Amadeus – flights + hotels (test = cached, production = real-time)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# For real-time data use production URL (default below = test/cached):
# AMADEUS_BASE=https://api.amadeus.com

# Skyscanner – flights (affiliate; you earn on bookings)
SKYSCANNER_API_KEY=

# KAYAK – flights + hotels (affiliate)
KAYAK_API_KEY=
KAYAK_AFFILIATE_ID=

# Booking.com – hotels (affiliate)
BOOKING_API_KEY=
BOOKING_AFFILIATE_ID=
